# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.

# Hugging Face access token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_...

# Root directory where HF models/datasets are cached
HF_HOME=/scratch/hf-cache/huggingface

# HF datasets cache (usually a subdirectory of HF_HOME)
HF_DATASETS_CACHE=/scratch/hf-cache/huggingface/datasets

# Scratch space for training checkpoints, wandb runs, etc.
TRAINING_SCRATCH=/scratch/training
